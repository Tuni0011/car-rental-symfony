{% extends 'base.html.twig' %}

{% block title %}Car Details{% endblock %}

{% block body %}

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="mb-3">{{ car.model }}</h2>

        <hr>

        <p><strong>Model:</strong> {{ car.model }}</p>

        <p><strong>Price per day:</strong> {{ car.pricePerDay }} €</p>

        <p><strong>Car ID:</strong> {{ car.id }}</p>

        <p><strong>Description:</strong> This is a great rental car.</p>

        <div class="mt-4">
            <a href="{{ path('app_car_index') }}" class="btn btn-secondary">
                Back to list
            </a>
        </div>

    </div>

</div>

{% endblock %}
